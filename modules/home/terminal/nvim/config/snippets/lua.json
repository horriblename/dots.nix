{
	"defer enter": {
		"prefix": ["defer-enter", "vim-enter"],
		"body": [
			"local function enter_callback()",
			"	$0",
			"end",
			"if vim.v.vim_did_enter == 1 then",
			"	enter_callback()",
			"else",
			"	vim.api.nvim_create_autocmd(\"VimEnter\", {",
			"		callback = enter_callback,",
			"		once = true",
			"	})",
			"end"
		]
	},
	"autocmd": {
		"prefix": ["autocmd"],
		"body": [
			"local augroup = vim.api.nvim_create_augroup(\"${1:augroup_name}\", {clear = true})",
			"vim.api.nvim_create_autocmd({\"${2:Event}\"}, {",
			"    group = augroup,",
			"    callback = function(ev)",
			"       $0",
			"    end,",
			"})"
		]
	}
}
