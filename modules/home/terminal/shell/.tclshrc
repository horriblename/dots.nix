if {[info exists env(NIX_PROFILES)]} {
    lappend auto_path {*}[lmap {p} [lindex [array get env NIX_PROFILES] 2] {"$p/share"}]
}

if {!$tcl_interactive} {
    return
}

set env(SHELL) [info nameofexecutable]

package require tclreadline

# uncomment the following line to use
# tclreadline's fancy ls proc.
#
# namespace import tclreadline::ls

# tclreadline::Print is on (`yes') by default.
# This mimics the command echoing like in the
# non-readline interactive tclsh.
# If you don't like this, uncomment the following
# line.
#
# tclreadline::Print no

# uncomment the following line, if you want
# to change tclreadline's print behaviour
# frequently with less typing.
#
# namespace import tclreadline::Print

# store maximal this much lines in the history file
#
set tclreadline::historyLength 200

# disable tclreadline's script completer
#
# ::tclreadline::readline customcompleter ""

# automatically save the history after every
# command (instead of when cleanly exiting)
set tclreadline::autosave 1

variable ::pushd_stack
proc pushd {dir} {
    lappend ::pushd_stack [pwd]
    puts stderr $::pushd_stack
    cd $dir
}

proc popd {} {
    if {![info exists ::pushd_stack] || [llength $::pushd_stack] == 0} {
        error "popd: empty directory stack"
    }
    set last_i [expr {[llength $::pushd_stack] - 1}]
    cd [lindex $::pushd_stack $last_i]
    set ::pushd_stack [lreplace $::pushd_stack $last_i $last_i]
    puts stderr $::pushd_stack
}

proc c {args} {pushd {*}$args}

# TODO: completion
proc z {dir} {
    if {[catch {exec z -e $dir} results options]} {
        return $options $results
    }

    pushd $results
}

proc lfcd {args} {
    set dir [exec lf -print-last-dir {*}$args]
    if {$dir != ""} {
        pushd $dir
    }
}

namespace eval tclreadline {
    # note: the surrounding \x01...\x02 are required by readline
    set color(reset)   "\x01\x1b\[0m\x02"
    set color(green)   "\x01\x1b\[32m\x02"
    set color(red)     "\x01\x1b\[31m\x02"
    set color(orange)  "\x01\x1b\[33m\x02"
    set color(aqua)    "\x01\x1b\[36m\x02"
    set color(magenta) "\x01\x1b\[35m\x02"
    set color(grey)    "\x01\x1b\[37m\x02"

    set status 0

    proc prompt1 {} {
        namespace upvar ::tclreadline status status
        namespace upvar ::tclreadline color color
        set arrowPre [expr {
            $status == 0
            ? "$color(green)"
            : "$color(red)$status "
        }]
        return "\n$color(aqua)[pwd]\n$arrowPre> $color(reset)"
    }

    proc prompt2 {} {
        namespace upvar ::tclreadline color color
        return "$color(grey)...> $color(reset)"
    }

    proc always1 {args} {
        return 1
    }

    # custom main loop
    proc Loop {args} {

        eval Setup ${args}

        uplevel #0 {

            while {1} {

                if {[catch {
                    set prompt "% "
                    if {"" != [info procs ::tclreadline::prompt1]} {
                        set prompt [::tclreadline::prompt1]
                    }
                    set ::tclreadline::LINE [::tclreadline::readline read $prompt]
                    while {![::tclreadline::readline complete $::tclreadline::LINE]} {
                        append ::tclreadline::LINE "\n"
                        set prompt2 "> "
                        if {"" != [info procs ::tclreadline::prompt2]} {
                            set prompt2 [::tclreadline::prompt2]
                        }
                        append ::tclreadline::LINE [tclreadline::readline read $prompt2]
                    }
                } ::tclreadline::errorMsg]} {
                    puts stderr "tclreadline::Loop: error. $::tclreadline::errorMsg"
                    continue
                }

                # Magnus Eriksson <magnus.eriksson@netinsight.se> proposed
                # to add the line also to tclsh's history.
                #
                # I decided to add only lines which are different from
                # the previous one to the history. This is different
                # from tcsh's behaviour, but I found it quite convenient
                # while using mshell on os9.
                #
                if {[string length $::tclreadline::LINE]
                        && [history event 0] != $::tclreadline::LINE} {
                    history add $::tclreadline::LINE
                    if {[info exists ::tclreadline::autosave] && \
                        [string is true -strict $::tclreadline::autosave] && \
                        [catch {::tclreadline::readline write [::tclreadline::HistoryFileGet]} \
                             ::tclreadline::errorMsg]} {
                        puts stderr $::tclreadline::errorMsg
                    }
                }

                if {[
                    catch {eval $::tclreadline::LINE} ::tclreadline::result options
                ]} {
                    if {[dict exists $options -errorcode]
                        && [::tclreadline::always1 [
                            set details [dict get $options -errorcode]]]
                        && [lindex $details 0] eq "CHILDSTATUS"} \
                    {
                        set ::tclreadline::status [lindex $details 2]
                    } elseif {$::tclreadline::result != "" && [tclreadline::Print]} {
                        set ::tclreadline::status {-1}
                        puts $::tclreadline::result
                    }
                } else {
                    set ::tclreadline::status 0
                }

            }
        }
    }
}

tclreadline::Loop


# vim: ft=tcl
